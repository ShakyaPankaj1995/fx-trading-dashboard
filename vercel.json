{
  "rewrites": [
    {
      "source": "/api/finance/(.*)",
      "destination": "/api/finance"
    },
    {
      "source": "/api/log",
      "destination": "/api/log"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "crons": [
    {
      "path": "/api/cron",
      "schedule": "* * * * *"
    }
  ]
}
